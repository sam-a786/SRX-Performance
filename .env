MONGO_URL=mongodb://localhost:27017
DB_NAME=srx_performance
NEXT_PUBLIC_BASE_URL=https://vehicle-calibration.preview.emergentagent.com
CORS_ORIGINS=*

# ==== SRX PERFORMANCE ENV ====
# Resend transactional email
# RESEND_API_KEY is set in Vercel's Environment Variables (never commit real key).
RESEND_API_KEY=
RESEND_FROM_EMAIL=SRX Performance <onboarding@resend.dev>
CONTACT_TO_EMAIL=performance.srx@gmail.com

# UK Vehicle Lookup API provider. Options:
#   'none' (default - manual entry mode; no lookup performed)
#   'ukvd' (UK Vehicle Data - paid, full spec incl. BHP/torque - RECOMMENDED)
#   'vdg'  (VehicleDataGlobal - paid)
#   'vd'   (Vehicle Databases - paid)
#   'dvla' (DVLA VES - free but registrations currently closed in the UK)
# Adding a provider later is as simple as setting the env vars below and restarting.
VEHICLE_API_PROVIDER=none
DVLA_API_KEY=
UKVD_API_KEY=
VDG_API_KEY=
VD_API_KEY=

# Google Tag Manager / Analytics (add later - exposed to client)
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_GADS_ID=AW-18261047881
# Google Ads conversion label for lead/appointment conversions (from your Google Ads account)
NEXT_PUBLIC_GADS_LEAD_LABEL=ylSRCMX6jcMcEMn0xYNE
# Google Ads conversion label for "Click to call" conversions
NEXT_PUBLIC_GADS_CALL_LABEL=vh5rCMKO1tMcEMn0xYNE
