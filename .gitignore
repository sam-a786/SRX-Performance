# ============================================
# SRX Performance — .gitignore
# ============================================

# Dependencies
/node_modules
/.pnp
.pnp.js

# Next.js build output
/.next/
/out/
/build

# Testing
/coverage

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# System
.DS_Store
*.pem

# .env is committed with all non-secret config values.
# Secrets (e.g. RESEND_API_KEY) are set in Vercel Environment Variables.
# .env.local files remain gitignored for developer overrides.
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Emergent scaffolding (safe to ignore)
/tests/
/memory/
/.emergent/
/public/srx-performance.zip
